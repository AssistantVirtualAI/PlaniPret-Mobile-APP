{
  "name": "planipret-mobile",
  "version": "1.0.0",
  "description": "Planiprêt — Standalone Capacitor Mobile App (iOS + Android)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:fast": "vite build --mode fast",
    "postbuild": "echo build complete",
    "preview": "vite preview",
    "test": "vitest run",
    "audit:native": "node scripts/audit-native.mjs",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android",
    "sync:ios": "npm run build && cap sync ios",
    "sync:android": "npm run build && cap sync android",
    "build:ios": "npm run build && cap sync ios && cap open ios",
    "build:android": "npm run build && cap sync android && cap open android",
    "native:ios": "npm run build:ios",
    "native:android": "npm run build:android",
    "ios:fast": "bash scripts/ios-fast.sh",
    "ios:fast:dev": "bash scripts/ios-fast.sh --dev",
    "ios:fast:full": "bash scripts/ios-fast.sh --full",
    "audit:parity": "node scripts/audit-parity.mjs",
    "build:ios:dev": "vite build --mode development && cap copy ios && cap open ios",
    "precheck:build": "node scripts/precheck-build.mjs",
    "ios:build-sync": "npm run build && npm run precheck:build && npx cap sync ios",
    "android:build-sync": "npm run build && npm run precheck:build && npx cap sync android",
    "sync:ios:fast": "npm run build && cap copy ios"
  },
